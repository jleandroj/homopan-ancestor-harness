# ── Large data (not for git) ─────────────────────────────────────────────
# Trailing-slash patterns don't match symlinks-to-dirs, so anchor the
# symlinked data names explicitly (root-anchored) as well.
genomes/
raw/
zips/
test_genomes/
/genomes
/test_genomes
/results
/primates.seqfile
/primates.test.seqfile

# ── Container image (~425 MB) ───────────────────────────────────────────
*.sif
apptainer_cache/
apptainer_tmp/

# ── Pipeline working data ───────────────────────────────────────────────
work/
results/
# Per-agent namespaced state (HOMOPAN_RUN_NS): runs/<NS>/{targets,results,work,...}
runs/

# ── Security / ephemeral ────────────────────────────────────────────────
.claude/.gate_pass
.claude/.posttool_error
.claude/.posttool_seq

# ── Logs (bitacora may contain commands) ─────────────────────────────────
logs/
*.lock

# ── Jobstore inputs sidecars (runtime, P1-f) ─────────────────────────────
*.inputs

# ── Archived old harness (reference only) ────────────────────────────────
_old_harness_review/

# ── Subproject with human-subject data ───────────────────────────────────
il10_analisis/

# ── OS / editor artifacts ───────────────────────────────────────────────
.DS_Store
*.swp
*.swo
*~
.vscode/
.idea/
