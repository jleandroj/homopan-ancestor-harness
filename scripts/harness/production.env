# production.env -- the strict production policy for the harness. Source it so
# the safety guarantees are ENFORCED, not optional:
#
#   set -a; source scripts/harness/production.env; set +a
#   bash scripts/run_supervised.sh full
#
# Closes gap #3: the orchestrators refuse to run outside the supervisor, compute
# must be sandboxed (fail-closed), and the audit chain is anchored to an external
# append-only log (admin should: chattr +a "$HOMOPAN_AUDIT_LOG").
export HOMOPAN_REQUIRE_HARNESS=1                 # run_all_*.sh die if not supervised
export HARNESS_SANDBOX="${HARNESS_SANDBOX:-1}"   # bwrap or fail-closed (override per host)
export HARNESS_TIMEOUT="${HARNESS_TIMEOUT:-172800}"
export HOMOPAN_AUDIT_LOG="${HOMOPAN_AUDIT_LOG:-${HOME}/.homopan_audit.jsonl}"
# Read auditing is opt-in (noise control); clinical access is denied+recorded at the gate.
export HOMOPAN_LOG_READS="${HOMOPAN_LOG_READS:-0}"
