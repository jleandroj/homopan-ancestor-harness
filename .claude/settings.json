{
  "permissions": {
    "deny": [
      "Read(./il10_analisis/**)",
      "Edit(./il10_analisis/**)",
      "Write(./il10_analisis/**)",
      "Write(./CLAUDE.md)",
      "Edit(./CLAUDE.md)",
      "Write(./agents.md)",
      "Edit(./agents.md)",
      "Write(./init.sh)",
      "Edit(./init.sh)",
      "Write(./.claude/gate_check.sh)",
      "Edit(./.claude/gate_check.sh)",
      "Write(./.claude/bitacora_log.sh)",
      "Edit(./.claude/bitacora_log.sh)",
      "Write(./.claude/settings.json)",
      "Edit(./.claude/settings.json)",
      "Write(./.claude/.gate_pass)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(nc:*)",
      "WebFetch",
      "WebSearch"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/gate_check.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/bitacora_log.sh"
          }
        ]
      }
    ]
  }
}
